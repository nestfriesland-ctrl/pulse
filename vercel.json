{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=300, stale-while-revalidate" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/liquidity-tide",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/liquidity-sweep-poll",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/macro-regime",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/infra",
      "schedule": "0 */1 * * *"
    },
    {
      "path": "/api/cron/market",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/watchlist",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/confluence",
      "schedule": "0 */4 * * *"
    }
  ]
}
